OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Anthropic Claude (fault classifier)
ANTHROPIC_API_KEY=sk-ant-...
CLASSIFIER_MODEL=claude-sonnet-4-6
CLASSIFIER_SIMILAR_TOP_K=3

# Embedding backend: "sentence_transformers" (local, no API key) or "openai"
EMBEDDING_BACKEND=sentence_transformers
ST_MODEL=all-MiniLM-L6-v2
ST_DEVICE=cpu
EMBEDDING_MODEL=text-embedding-3-small

CHROMA_HOST=localhost
CHROMA_PORT=8001
TICKET_COLLECTION=tickets
SOP_COLLECTION=sops
DATABASE_URL=sqlite+aiosqlite:///./data/tickets.db
WEBHOOK_SECRET=changeme-use-strong-secret
ENVIRONMENT=development
LOG_LEVEL=INFO
SIMILARITY_TOP_K=5
SOP_TOP_K=3
SIMILARITY_SCORE_THRESHOLD=0.75

# Embedding pipeline
EMBEDDING_PIPELINE_TOP_K=3
EMBEDDING_PIPELINE_THRESHOLD=0.0

# Alarm subsystem
ALARM_RETENTION_DAYS=30
ALARM_CLEARED_HOLD_MINUTES=30

# Maintenance subsystem
MAINTENANCE_LOOKAHEAD_HOURS=4
MAINTENANCE_LOOKBACK_HOURS=1

# Correlation engine
CORRELATION_SIMILAR_K=5
CORRELATION_SOP_K=3
